# LLM API Settings (Get free API key from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# JWT Settings
SECRET_KEY=change-this-secret-key-in-production-make-it-very-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (Local SQLite only)
DATABASE_URL=sqlite:///./quickcommerce.db

# Environment
ENVIRONMENT=development

# Weather API (Optional - for contextual triggers)
# Get free key from https://openweathermap.org/api
WEATHER_API_KEY=

# Business Rules
FREE_DELIVERY_THRESHOLD=399.0
DELIVERY_CHARGE=49.0
