# LLM API Settings (Get free API key from https://console.groq.com)
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL=llama-3.3-70b-versatile

# JWT Settings
SECRET_KEY="change-this-secret-key-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (Local SQLite only)
DATABASE_URL=sqlite:///./quickcommerce.db

# Environment
ENVIRONMENT=development

# Weather API (for contextual triggers - https://www.weatherapi.com)
WEATHER_API_KEY="your-weatherapi-key-here"
WEATHER_API_CITY=Mumbai

# Business Rules
FREE_DELIVERY_THRESHOLD=399.0
DELIVERY_CHARGE=49.0
COUPON_THRESHOLD=499.0
COUPON_DISCOUNT=75.0
